# --- Backend — set in Vercel Project → Environment Variables (Production) ---

# MongoDB Atlas (required for API routes that use the database)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/sriram_ias_admin?retryWrites=true&w=majority

# Optional: standard mongodb:// URI if SRV DNS fails locally
# MONGO_URI_DIRECT=mongodb://<user>:<password>@host:27017/sriram_ias_admin?ssl=true&authSource=admin

# Optional: override DNS for Atlas SRV lookups
# DNS_SERVERS=8.8.8.8,8.8.4.4

# Custom frontend URL(s) for CORS — comma-separated for multiple origins
# CLIENT_ORIGIN=http://localhost:5173
# CLIENT_ORIGINS=http://localhost:5173,https://your-production-domain.com
# FRONTEND_URL=https://your-production-domain.com

# Remote master-management API (programs, categories, subjects, etc.)
# Used by the local backend gateway to avoid browser CORS in development.
# REMOTE_API_URL=https://new-sriramias.onrender.com

# Local only (Vercel sets PORT automatically)
PORT=5000

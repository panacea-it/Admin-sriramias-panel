# --- Local development (optional backend) ---

# Frontend-only mode (no API calls). Set true for Vercel-style local testing.
# VITE_FRONTEND_ONLY=true

# Global API host (no trailing slash). Used by src/config/api.js and Vite /api proxy.
VITE_BASE_URL=https://new-sriramias.onrender.com

# Legacy alias — still supported by axiosInstance / vite proxy
# VITE_API_BASE_URL=http://localhost:5000

# Super Admin login + live APIs (set false to force API for Super Admin in dev)
VITE_ENABLE_DEMO_LOGIN=false

# Demo / employee login (localStorage) — always on when VITE_FRONTEND_ONLY=true
VITE_ENABLE_DEMO_LOGIN=true

# Module mocks (default true in .env.production)
# VITE_FINANCE_USE_MOCK=true
# VITE_SALES_ANALYTICS_USE_MOCK=true
# VITE_USE_CLASSROOM_API=false

# Bookstore module (mock data when true or frontend-only)
# VITE_BOOKSTORE_USE_MOCK=true

# OMR module — local storage until /api/omr/* is deployed (set false when backend is ready)
# VITE_OMR_USE_MOCK=true

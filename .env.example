# --- Local development ---

# Frontend-only mode (no API calls). Use only for offline UI testing.
# VITE_FRONTEND_ONLY=true

# API host (no trailing slash, no /api suffix). Used by Vite dev proxy and production builds.
# Local backend: http://localhost:5000 (backend must be running or login returns 502)
# Remote backend: https://sriramias-backend.onrender.com
VITE_API_BASE_URL=https://sriramias-backend.onrender.com

# Batch enrollments are served by the local backend in dev (vite proxies /api/batch-enrollments).
# Run: npm run dev:api  (requires MONGO_URI in backend/.env)
# VITE_LOCAL_API_URL=http://localhost:5000
# Alias supported by vite.config.js and src/config/api.js:
# VITE_API_URL=http://localhost:5000

# Fallback if VITE_API_BASE_URL is unset (vite.config.js proxy only)
# VITE_BASE_URL=https://sriramias-backend.onrender.com

# Verbose login debug logs in dev (default on; set false to silence)
# VITE_DEBUG_AUTH=false

# Super Admin: set false to use live API in dev
VITE_ENABLE_DEMO_LOGIN=false

# VITE_FRONTEND_ONLY=false

# Module mocks
# VITE_FINANCE_USE_MOCK=true
# VITE_SALES_ANALYTICS_USE_MOCK=true
# VITE_USE_CLASSROOM_API=false
# VITE_BOOKSTORE_USE_MOCK=true
# VITE_OMR_USE_MOCK=true
